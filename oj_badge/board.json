{
    "name": "OJBadge",
    "version": "1.0.1",
    "description": "OJBadge是一块ESP32-S3 智能终端，带1.28寸GC9A01圆形彩屏(240×240)、电容触摸、I2S 音频、电池管理,支持 USB 与 Wi-Fi/蓝牙。",
    "compilerTool": "aily-builder",
    "core": "esp32:esp32",
    "type": "esp32:esp32:esp32s3",
    "compilerParam": "compile -v -b esp32:esp32:esp32s3 --build-property build.flash_size=16MB --build-property build.partitions=app3M_fat9M_16MB --build-property build.cdc_on_boot=1",
    "uploadParam": "esptool --chip esp32s3 --port ${serial} --baud ${baud} --before default_reset --after hard_reset write_flash -z --flash_mode keep --flash_freq keep --flash_size keep 0x0 ${bootloader} 0x8000 ${partitions} 0xe000 ${boot_app0} 0x10000 ${'*.bin'}",
